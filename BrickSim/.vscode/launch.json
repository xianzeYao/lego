{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "program": "${file}",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Extension"
        },
        {
            "name": "Python: BrickSim",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "program": "${workspaceFolder}/.venv/bin/bricksim",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Extension"
        },
        {
            "name": "Python: BrickSim (Current File)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "program": "${workspaceFolder}/.venv/bin/bricksim",
            "args": [
                "${file}"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Extension"
        },
        {
            "name": "C++: Attach BrickSim",
            "type": "lldb",
            "request": "attach",
            "program": "${workspaceFolder}/.venv/bin/python",
            "pid": "${input:pid_bricksim}",
            "stopOnEntry": false,
            "initCommands": [
                "process handle --stop false --notify false SIGWINCH"
            ]
        },
        {
            "name": "C++: Attach BrickSim (Select process)",
            "type": "lldb",
            "request": "attach",
            "program": "${workspaceFolder}/.venv/bin/python",
            "pid": "${command:pickProcess}",
            "stopOnEntry": false,
            "initCommands": [
                "process handle --stop false --notify false SIGWINCH"
            ]
        },
        {
            "name": "C++: CMake Debug",
            "type": "lldb",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopOnEntry": false,
            "cwd": "${workspaceFolder}",
            "env": {
                "PATH": "${env:PATH}:${command:cmake.getLaunchTargetDirectory}"
            }
        }
    ],
    "compounds": [
        {
            "name": "Debug C++ & Python",
            "configurations": [
                "Python: BrickSim",
                "C++: Attach BrickSim"
            ],
            "preLaunchTask": "Build Extension",
            "stopAll": true
        },
        {
            "name": "Debug C++ & Python (Current File)",
            "configurations": [
                "Python: BrickSim (Current File)",
                "C++: Attach BrickSim"
            ],
            "preLaunchTask": "Build Extension",
            "stopAll": true
        }
    ],
    "inputs": [
        {
            "id": "pid_bricksim",
            "type": "command",
            "command": "shellCommand.execute",
            "args": {
                "command": "${workspaceFolder}/scripts/find_bricksim_pid.py",
                "useFirstResult": true
            }
        }
    ]
}
