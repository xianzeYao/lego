+    // Replace the existing mapped value with a new value. This is used by
+    // _ValueProxy::operator= to support assignment to elements obtained from
+    // iteration. There is no direct 'Set' primitive on Sdf_Children, so we
+    // update the in-memory sequence and perform a Copy to apply the change.
+    template <class U>
+    void _Set(const mapped_type& oldValue, const U& newValue)
+    {
+        if (_Validate(CanSet)) {
+            mapped_vector_type values = _view.values();
+
+            // Find the current value and replace it while preserving order.
+            for (size_t i = 0; i < values.size(); ++i) {
+                if (values[i] == oldValue) {
+                    values[i] = static_cast<mapped_type>(newValue);
+                    _PrimCopy(values);
+                    break;
+                }
+            }
+        }
+    }
